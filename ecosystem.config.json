{
  "apps": [
    {
      "name": "zulim-app",
      "script": "pnpm",
      "args": "start",
      "cwd": "/root/zulim-app",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "env": {
        "NODE_ENV": "production",
        "PORT": "3013"
      }
    }
  ]
}
