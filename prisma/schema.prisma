// Configuración de base de datos para PostgreSQL
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 0. Usuarios y Auth
enum Role {
  ADMIN
  SELLER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(SELLER)
  sales     Sale[]
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 1. Catálogo de Productos
model Product {
  id                String         @id @default(uuid())
  name              String
  sku               String         @unique
  description       String?
  unitType          UnitType       // KG, METERS, UNIT
  
  // Reglas de Venta
  minSaleQuantity   Float          @default(1)
  maxSaleQuantity   Float?
  
  // Precios Actuales
  purchasePrice     Decimal        @db.Decimal(10, 2) // Precio de compra
  profitMargin      Float                             // Margen en %
  retailPrice       Decimal        @db.Decimal(10, 2) // Precio por menor
  wholesalePrice    Decimal        @db.Decimal(10, 2) // Precio por mayor
  salePrice         Decimal        @db.Decimal(10, 2) // Precio final (con redondeo aplicado)
  
  stock             Float          @default(0)
  
  // Relaciones
  priceHistory      PriceHistory[]
  saleItems         SaleItem[]
  
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

// 2. Historial de Precios (Métricas de Inflación)
model PriceHistory {
  id                String   @id @default(uuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  
  oldPurchasePrice  Decimal  @db.Decimal(10, 2)
  newPurchasePrice  Decimal  @db.Decimal(10, 2)
  oldSalePrice      Decimal  @db.Decimal(10, 2)
  newSalePrice      Decimal  @db.Decimal(10, 2)
  
  changeDate        DateTime @default(now())
  reason            String?  // Ej: "Carga Masiva Excel" o "Ajuste Manual"
}

// 3. Ventas y Facturación
enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  DEBITO
  CREDITO
  MERCADOPAGO
}

enum InvoiceType {
  A
  B
  C
  TICKET
}

model Sale {
  id                String         @id @default(uuid())
  saleNumber        Int            @default(autoincrement())
  totalAmount       Decimal        @db.Decimal(10, 2)
  roundedAmount     Decimal        @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  
  sellerId          String?
  seller            User?          @relation(fields: [sellerId], references: [id])
  clientId          String?
  client            Client?        @relation(fields: [clientId], references: [id])
  items             SaleItem[]
  invoice           Invoice?
  
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model SaleItem {
  id                String   @id @default(uuid())
  saleId            String
  sale              Sale     @relation(fields: [saleId], references: [id])
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  
  quantity          Float
  unitPrice         Decimal  @db.Decimal(10, 2)
  subtotal          Decimal  @db.Decimal(10, 2)
  unitType          UnitType
}

// 5. Comprobantes AFIP
model Invoice {
  id                String       @id @default(uuid())
  saleId            String       @unique
  sale              Sale         @relation(fields: [saleId], references: [id])
  
  invoiceType       InvoiceType
  invoiceNumber     String
  cae               String?
  caeExpiration     DateTime?
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

// 4. Clientes (Adaptado para AFIP)
model Client {
  id                String   @id @default(uuid())
  name              String   // Razón Social o Nombre
  taxId             String   @unique // CUIT/CUIL/DNI para AFIP
  taxCondition      String   // Responsable Inscripto, Monotributo, Consumidor Final
  address           String?
  email             String?
  phone             String?
  sales             Sale[]
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum UnitType {
  KG
  METERS
  UNIT
}