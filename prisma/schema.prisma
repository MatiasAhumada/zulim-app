// Configuración de base de datos para PostgreSQL
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 0. Usuarios y Auth
enum Role {
  ADMIN
  SELLER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(SELLER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 1. Catálogo de Productos
model Product {
  id                String         @id @default(uuid())
  name              String
  sku               String         @unique
  description       String?
  unitType          UnitType       // KG, METERS, UNIT
  
  // Reglas de Venta
  minSaleQuantity   Float          @default(1)
  maxSaleQuantity   Float?
  
  // Precios Actuales
  purchasePrice     Decimal        @db.Decimal(10, 2) // Precio de compra
  profitMargin      Float                             // Margen en %
  retailPrice       Decimal        @db.Decimal(10, 2) // Precio por menor
  wholesalePrice    Decimal        @db.Decimal(10, 2) // Precio por mayor
  salePrice         Decimal        @db.Decimal(10, 2) // Precio final (con redondeo aplicado)
  
  stock             Float          @default(0)
  
  // Relaciones
  priceHistory      PriceHistory[]
  saleItems         SaleItem[]
  
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

// 2. Historial de Precios (Métricas de Inflación)
model PriceHistory {
  id                String   @id @default(uuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  
  oldPurchasePrice  Decimal  @db.Decimal(10, 2)
  newPurchasePrice  Decimal  @db.Decimal(10, 2)
  oldSalePrice      Decimal  @db.Decimal(10, 2)
  newSalePrice      Decimal  @db.Decimal(10, 2)
  
  changeDate        DateTime @default(now())
  reason            String?  // Ej: "Carga Masiva Excel" o "Ajuste Manual"
}

// 3. Ventas y Facturación
model Sale {
  id                String      @id @default(uuid())
  totalAmount       Decimal     @db.Decimal(10, 2)
  roundedAmount     Decimal     @db.Decimal(10, 2) // Valor final a la centena
  paymentMethod     String      // Efectivo, Transferencia, etc.
  
  // Integración AFIP
  invoiceType       String?     // A, B, C o Ticket
  cae               String?     // Código de Autorización Electrónico de AFIP
  caeExpiration     DateTime?
  
  clientId          String?
  client            Client?     @relation(fields: [clientId], references: [id])
  items             SaleItem[]
  
  createdAt         DateTime    @default(now())
}

model SaleItem {
  id                String   @id @default(uuid())
  saleId            String
  sale              Sale     @relation(fields: [saleId], references: [id])
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  
  quantity          Float
  priceAtSale       Decimal  @db.Decimal(10, 2)
}

// 4. Clientes (Adaptado para AFIP)
model Client {
  id                String   @id @default(uuid())
  name              String   // Razón Social o Nombre
  taxId             String   @unique // CUIT/CUIL/DNI para AFIP
  taxCondition      String   // Responsable Inscripto, Monotributo, Consumidor Final
  address           String?
  email             String?
  sales             Sale[]
}

enum UnitType {
  KG
  METERS
  UNIT
}